# Publication automation — environment variables
# Copy to .env and fill in tokens. Never commit .env with real secrets.

# --- Zenodo (Agent 2) ---
ZENODO_ACCESS_TOKEN=
ZENODO_USE_SANDBOX=true

# --- Figshare (Agent 3) ---
FIGSHARE_TOKEN=

# --- arXiv (Agent 4) ---
ARXIV_USERNAME=
ARXIV_PASSWORD=

# --- OSF / EarthArXiv (Agent 5) ---
OSF_TOKEN=
OSF_PROJECT_ID=

# --- Data repositories (Agent 6) ---
PANGAEA_TOKEN=
GFZ_TOKEN=
DRYAD_TOKEN=

# --- Social uploads (Agent 7) — Selenium, manual CAPTCHA ---
SOCIAL_UPLOAD_LIVE=false
SELENIUM_HEADLESS=false
RESEARCHGATE_EMAIL=
RESEARCHGATE_PASSWORD=
ACADEMIA_EMAIL=
ACADEMIA_PASSWORD=

# --- Social announcements (optional) ---
TWITTER_BEARER_TOKEN=
LINKEDIN_ACCESS_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- GitHub (README update stub) ---
GITHUB_TOKEN=
