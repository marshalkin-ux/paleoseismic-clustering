{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Master Publication Metadata",
  "type": "object",
  "required": [
    "title_en",
    "title_ru",
    "abstract_en",
    "abstract_ru",
    "authors",
    "github_url",
    "publication_date",
    "files"
  ],
  "properties": {
    "title_en": { "type": "string" },
    "title_ru": { "type": "string" },
    "abstract_en": { "type": "string" },
    "abstract_ru": { "type": "string" },
    "keywords_en": { "type": "array", "items": { "type": "string" } },
    "keywords_ru": { "type": "array", "items": { "type": "string" } },
    "authors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name_en": { "type": "string" },
          "name_ru": { "type": "string" },
          "email": { "type": "string" },
          "orcid": { "type": "string" }
        }
      }
    },
    "affiliations": { "type": "array" },
    "doi": { "type": "string" },
    "zenodo_url": { "type": "string" },
    "figshare_doi": { "type": "string" },
    "arxiv_id": { "type": "string" },
    "osf_url": { "type": "string" },
    "eartharxiv_url": { "type": "string" },
    "pangaea_doi": { "type": "string" },
    "gfz_doi": { "type": "string" },
    "dryad_doi": { "type": "string" },
    "researchgate_status": { "type": "string" },
    "academia_status": { "type": "string" },
    "github_url": { "type": "string" },
    "publication_date": { "type": "string" },
    "files": { "type": "object" },
    "platform_status": { "type": "object" }
  }
}
